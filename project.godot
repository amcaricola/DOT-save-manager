; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="DOT_save Tool"
config/features=PackedStringArray("4.7", "Forward Plus")

[autoload]

DOT_SaveManager="*uid://ctt30dnwyf7w6"
DOT_save="*uid://ctt30dnwyf7w6"

[debug]

gdscript/warnings/untyped_declaration=2
gdscript/warnings/inferred_declaration=2

[editor_plugins]

enabled=PackedStringArray("res://addons/dot_save_manager/plugin.cfg", "res://addons/simple_save_tool/plugin.cfg")

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
